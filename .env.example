# Observability — HTTPS URL of the observabilityIngest function after deploy:
# firebase deploy --only functions:observabilityIngest
# Example: https://us-central1-YOUR_PROJECT.cloudfunctions.net/observabilityIngest
VITE_OBSERVABILITY_ENDPOINT=
# Optional: shown on ingested documents; defaults to import.meta.env.MODE
# VITE_APP_VERSION=

# Supabase (client)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_BUCKET=

# EmailJS (client)
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
