rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // Admin users should have a custom claim: { admin: true }
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isString(v) {
      return v is string;
    }

    function isBool(v) {
      return v is bool;
    }

    function validListingType(v) {
      return v in ['land', 'property', 'shop'];
    }

    function validLandStatus(v) {
      return v in ['available', 'sold-out'];
    }

    function validTourType(v) {
      return v in ['in-person', 'video'];
    }

    function validEventStatus(v) {
      return v in ['draft', 'published', 'past', 'cancelled'];
    }

    function validContactStatus(v) {
      return v in ['new', 'contacted', 'closed'];
    }

    function validBlogStatus(v) {
      return v in ['draft', 'published'];
    }

    function validEmail(v) {
      return v.matches('^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$');
    }

    match /projects/{projectId} {
      // Public listing access
      allow read: if true;

      // Admin-only writes
      allow create, update, delete: if isAdmin()
        && isString(request.resource.data.id)
        && isString(request.resource.data.title)
        && request.resource.data.title.size() >= 3
        && isString(request.resource.data.location)
        && request.resource.data.location.size() >= 2
        && isString(request.resource.data.listingType)
        && validListingType(request.resource.data.listingType)
        && isString(request.resource.data.price)
        && isBool(request.resource.data.featured)
        && (!('landOptionStatus' in request.resource.data) || validLandStatus(request.resource.data.landOptionStatus))
        && (!('landOptionFeatured' in request.resource.data) || isBool(request.resource.data.landOptionFeatured))
        && (!('plotOptions' in request.resource.data) || (request.resource.data.plotOptions is list && request.resource.data.plotOptions.size() <= 100));
    }

    match /tour_requests/{tourId} {
      // Only admins can read/manage requests
      allow read, update, delete: if isAdmin();

      // Public inspection request create with payload checks
      allow create: if
        tourId == request.resource.data.date + '_' + request.resource.data.time
        &&
        isString(request.resource.data.projectId)
        && isString(request.resource.data.projectTitle)
        && isString(request.resource.data.projectLocation)
        && isString(request.resource.data.tourType)
        && validTourType(request.resource.data.tourType)
        && isString(request.resource.data.date)
        && request.resource.data.date.matches('^\\d{4}-\\d{2}-\\d{2}$')
        && isString(request.resource.data.time)
        && request.resource.data.time.matches('^\\d{2}:\\d{2}$')
        && isString(request.resource.data.name)
        && request.resource.data.name.size() >= 2
        && request.resource.data.name.size() <= 120
        && isString(request.resource.data.phone)
        && request.resource.data.phone.size() >= 7
        && request.resource.data.phone.size() <= 25
        && isString(request.resource.data.email)
        && request.resource.data.email.size() >= 5
        && request.resource.data.email.size() <= 254
        && validEmail(request.resource.data.email)
        && isString(request.resource.data.message)
        && request.resource.data.message.size() <= 1000;
    }

    match /contact_requests/{requestId} {
      // Only admins can view/manage contact leads
      allow read, delete: if isAdmin();

      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status'])
        && isString(request.resource.data.status)
        && validContactStatus(request.resource.data.status);

      // Public contact request create with strict payload validation
      allow create: if
        request.resource.data.keys().hasOnly(['name', 'email', 'subject', 'message', 'source', 'mobile', 'status', 'createdAt'])
        && request.resource.data.createdAt is timestamp
        && isString(request.resource.data.name)
        && request.resource.data.name.size() >= 2
        && request.resource.data.name.size() <= 120
        && isString(request.resource.data.email)
        && request.resource.data.email.size() >= 5
        && request.resource.data.email.size() <= 254
        && validEmail(request.resource.data.email)
        && isString(request.resource.data.subject)
        && request.resource.data.subject.size() >= 3
        && request.resource.data.subject.size() <= 120
        && isString(request.resource.data.message)
        && request.resource.data.message.size() >= 10
        && request.resource.data.message.size() <= 2000
        && isString(request.resource.data.source)
        && request.resource.data.source.size() >= 3
        && request.resource.data.source.size() <= 60
        && (!('mobile' in request.resource.data) || isString(request.resource.data.mobile))
        && isString(request.resource.data.status)
        && request.resource.data.status == 'new';
    }

    match /blog_posts/{postId} {
      // Public can read only published posts
      allow read: if isAdmin() || (resource.data.status == 'published');

      // Admin-only blog management
      allow create, update, delete: if isAdmin()
        && isString(request.resource.data.id)
        && isString(request.resource.data.title)
        && request.resource.data.title.size() >= 5
        && request.resource.data.title.size() <= 180
        && isString(request.resource.data.slug)
        && request.resource.data.slug.matches('^[a-z0-9]+(?:-[a-z0-9]+)*$')
        && isString(request.resource.data.excerpt)
        && request.resource.data.excerpt.size() >= 20
        && request.resource.data.excerpt.size() <= 600
        && isString(request.resource.data.content)
        && request.resource.data.content.size() >= 120
        && request.resource.data.content.size() <= 30000
        && isString(request.resource.data.coverImage)
        && request.resource.data.coverImage.size() <= 5000
        && request.resource.data.tags is list
        && request.resource.data.tags.size() <= 20
        && isString(request.resource.data.status)
        && validBlogStatus(request.resource.data.status)
        && isString(request.resource.data.author)
        && request.resource.data.author.size() <= 120
        && isString(request.resource.data.publishedAt)
        && isString(request.resource.data.updatedAt)
        && isString(request.resource.data.createdAt);
    }

    match /events/{eventId} {
      // Public can only read published events, admins can read all
      allow read: if isAdmin() || (resource.data.status == 'published');

      // Admin-only event management
      allow create, update, delete: if isAdmin()
        && isString(request.resource.data.title)
        && request.resource.data.title.size() >= 3
        && request.resource.data.title.size() <= 150
        && isString(request.resource.data.date)
        && request.resource.data.date.size() >= 4
        && request.resource.data.date.size() <= 40
        && isString(request.resource.data.time)
        && request.resource.data.time.size() >= 1
        && request.resource.data.time.size() <= 40
        && isString(request.resource.data.location)
        && request.resource.data.location.size() >= 2
        && request.resource.data.location.size() <= 160
        && isString(request.resource.data.description)
        && request.resource.data.description.size() >= 3
        && request.resource.data.description.size() <= 3000
        && isString(request.resource.data.status)
        && validEventStatus(request.resource.data.status)
        && (!('featured' in request.resource.data) || isBool(request.resource.data.featured))
        && (!('image' in request.resource.data) || isString(request.resource.data.image))
        && (!('registrationLink' in request.resource.data) || isString(request.resource.data.registrationLink));
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}